# Normalise all text files to LF in the repository.
# Git will convert to CRLF on Windows checkouts automatically.
* text=auto eol=lf

# Explicitly binary – never convert.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.xlsx binary
*.sqlite3 binary
